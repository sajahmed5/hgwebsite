# ── Email delivery for the enquiry & job-application forms ──────────────
# Copy this file to ".env.local" for local dev, and add the same values in
# your host's dashboard (e.g. Vercel → Settings → Environment Variables).
#
# Without RESEND_API_KEY the forms still work — submissions are logged to the
# server console instead of emailed.

# 1) Sign up free at https://resend.com and create an API key:
RESEND_API_KEY=

# 2) Where enquiries should land (defaults to hello@hgcare.co.uk):
CONTACT_TO_EMAIL=hello@hgcare.co.uk

# 3) The "from" address. To use your own domain, verify hgcare.co.uk in
#    Resend, then set e.g. "HG Care <noreply@hgcare.co.uk>".
#    Until then you can leave this blank to use Resend's test sender.
CONTACT_FROM_EMAIL=
